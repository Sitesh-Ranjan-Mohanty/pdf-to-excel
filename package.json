{
  "name": "ocr-to-excel",
  "version": "1.0.0",
  "description": "Monorepo OCR to Excel app with React frontend and Node backend",
  "main": "backend/server.js",
  "scripts": {
    "start": "concurrently \"npm run backend:start\" \"npm run frontend:start\"",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "backend:start": "node backend/server.js",
    "backend:start:render": "npm run build && node backend/server.js",
    "backend:dev": "nodemon backend/server.js",
    "frontend:start": "vite --config frontend/vite.config.mjs",
    "frontend:dev": "vite --config frontend/vite.config.mjs",
    "build": "vite build --config frontend/vite.config.mjs"
  },
  "keywords": [
    "ocr",
    "react",
    "nodejs",
    "monorepo",
    "excel"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "nodemon": "^3.1.10",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tesseract.js": "^7.0.0",
    "vite": "^5.4.18",
    "xlsx": "^0.18.5"
  }
}
